# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/activia_trace

# Security
SECRET_KEY=please-change-this-to-a-minimum-of-32-chars
ENCRYPTION_KEY=please-change-this-32-char-key!
